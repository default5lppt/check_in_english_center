generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(cuid())
  name      String
  color     String
  bg        String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  timings  SchoolTiming[]
  sessions ScheduleSession[]
  classes  Class[]
  rooms    Room[]
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  color     String
  createdAt DateTime @default(now())

  entries ClassEntry[]
}

model TeachingAssistant {
  id        String   @id @default(cuid())
  name      String
  color     String
  createdAt DateTime @default(now())

  entries ClassEntry[]
}

model Class {
  id        String   @id @default(cuid())
  name      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  entries ClassEntry[]

  @@unique([name, schoolId])
}

model Room {
  id        String   @id @default(cuid())
  name      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  entries ClassEntry[]

  @@unique([name, schoolId])
}

model GlobalSetting {
  id           String @id @default("singleton")
  period1Start String @default("14:00")
}

model SchoolTiming {
  id           String @id @default(cuid())
  schoolId     String @unique
  school       School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  period2Start String
  period3Start String
}

model ScheduleSession {
  id          String   @id @default(cuid())
  weekStart   String
  dayIndex    Int
  periodIndex Int
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries ClassEntry[]

  @@unique([weekStart, dayIndex, periodIndex, schoolId])
}

model ClassEntry {
  id        String             @id @default(cuid())
  sessionId String
  session   ScheduleSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   Teacher?           @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  taId      String?
  ta        TeachingAssistant? @relation(fields: [taId], references: [id], onDelete: SetNull)
  classId   String?
  class     Class?             @relation(fields: [classId], references: [id], onDelete: SetNull)
  roomId    String?
  room      Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  order     Int                @default(0)
  createdAt DateTime           @default(now())
}
